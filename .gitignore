.DS_Store
__pycache__/
.pytest_cache/
.venv/
node_modules/
.next/
.next-e2e/
dist/
coverage/
*.tsbuildinfo
.task-runs/
.playwright-mcp/
playwright-report/
test-results/
next-env.d.ts

# Never commit secrets. Templates (.env.example) are the only allowed entries.
.env
.env.*
!.env.example

# Local screenshots captured during manual verification or by agent
# codegen (Playwright evaluation, debug captures). Root-level PNGs
# are never source assets — anything that ships lives in public/ or
# docs/assets/, not at the repo root. Applying the rule broadly
# prevents stray debug artifacts from leaking into PRs and blocking
# merge-check.
/*.png
